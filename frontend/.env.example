# Pom Order Frontend — Environment variables
# Copy to .env and fill in values

# Backend API base URL (Vite dev server proxies /api to this)
VITE_API_BASE_URL=http://localhost:8000

# Supabase (public values — anon key is safe in frontend)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
