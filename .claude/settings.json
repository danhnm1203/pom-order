      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); if echo \"$FILE\" | grep -qE '\\.(md|txt)$' && ! echo \"$FILE\" | grep -qE '(docs/|\\.claude/|locales/|CHANGELOG|README|LICENSE)'; then echo \"WARNING: Creating markdown file outside docs/.claude/locales/: $FILE. Consider placing in .claude/skills/ or docs/ instead.\" >&2; fi; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
