# Pom Order Backend — Environment variables
# Copy to .env and fill in values

# Supabase project URL (local default shown)
SUPABASE_URL=http://127.0.0.1:54321

# Supabase anon key (find in Studio > Settings > API, or `supabase status`)
SUPABASE_ANON_KEY=

# Supabase service role key (BACKEND ONLY — never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret (find in Studio > Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=

# Database URL (asyncpg driver) — local Supabase default
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres

# API config
API_TITLE=Pom Order API
API_VERSION=0.1.0
CORS_ORIGINS=http://localhost:5173

# Default shop ID (single-tenant MVP)
DEFAULT_SHOP_ID=00000000-0000-0000-0000-000000000001

# Logging
LOG_LEVEL=INFO
